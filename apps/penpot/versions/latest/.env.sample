# 容器名称前缀
CONTAINER_NAME=penpot

# 公共访问地址
PUBLIC_URI=http://localhost

# 数据库配置
DB_USER=penpot
DB_PASSWORD=penpot
DB_NAME=penpot

# 前端端口
FRONTEND_PORT=80

# 后端端口
BACKEND_PORT=6060

# 是否启用遥测
TELEMETRY_ENABLED=false

# SMTP 邮件配置（可选）
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_TLS=true
SMTP_FROM=noreply@example.com

# 存储后端配置
# assets-db: 数据库存储（默认）
# assets-fs: 文件系统存储
STORAGE_BACKEND=assets-db

# 文件系统存储配置（当 STORAGE_BACKEND=assets-fs 时使用）
ASSETS_URI=/assets

# 是否允许导出到本地主机
ALLOW_LOCAL_HOSTS=false

# Google OAuth 配置（可选）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth 配置（可选）
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitLab OAuth 配置（可选）
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
