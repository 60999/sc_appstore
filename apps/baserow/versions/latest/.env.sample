# 容器名称
CONTAINER_NAME=baserow

# 访问地址
PUBLIC_URL=http://localhost

# 数据库配置
DB_USER=baserow
DB_PASSWORD=baserow
DB_NAME=baserow

# HTTP 端口
HTTP_PORT=80

# HTTPS 端口
HTTPS_PORT=443

# 密钥配置（请修改为随机字符串）
SECRET_KEY=change-this-to-a-random-string
JWT_KEY=change-this-to-a-random-string

# 时区设置
TIMEZONE=Asia/Shanghai

# SMTP 邮件配置（可选）
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_TLS=true

# 是否允许 Webhook 访问私有地址
ALLOW_PRIVATE_ADDRESS=false
