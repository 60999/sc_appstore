# 容器名称前缀
CONTAINER_NAME=vikunja

# 数据库配置
DB_USER=vikunja
DB_PASSWORD=vikunja
DB_NAME=vikunja

# API 端口
API_PORT=3456

# 前端端口
FRONTEND_PORT=8080

# JWT 密钥（请修改为随机字符串）
JWT_SECRET=your-secret-key-change-this

# 前端访问地址
FRONTEND_URL=http://localhost:8080

# API 访问地址
API_URL=http://localhost:3456/api/v1

# 是否启用 Othello
ENABLE_OTHELLO=true
