# 容器名称
CONTAINER_NAME=rmqtt

# 节点ID（单节点模式使用默认值1）
NODE_ID=1

# MQTT 端口
MQTT_PORT=1883

# MQTT TLS 端口
MQTTS_PORT=8883

# HTTP API 端口
HTTP_PORT=6060

# gRPC 端口
GRPC_PORT=5363

# Raft 端口
RAFT_PORT=6003

# 时区设置
TIMEZONE=Asia/Shanghai

# 默认启动插件（单节点模式留空）
# PLUGINS_DEFAULT_STARTUPS=rmqtt-cluster-raft

# 集群节点 gRPC 地址（多节点模式配置）
# NODE_GRPC_ADDRS=1@172.17.0.3:5363 2@172.17.0.4:5363 3@172.17.0.5:5363

# Raft 节点地址（多节点模式配置）
# RAFT_PEER_ADDRS=1@172.17.0.3:6003 2@172.17.0.4:6003 3@172.17.0.5:6003
